class Solution {
public:
    vector<int> sumAndMultiply(string s, vector<vector<int>>& queries) {
        const long long MOD = 1000000007;

        vector<int> pos, digit;
        for (int i = 0; i < s.size(); i++) {
            if (s[i] != '0') {
                pos.push_back(i);
                digit.push_back(s[i] - '0');
            }
        }

        int k = pos.size();

        vector<long long> pow10(k + 1, 1), prefVal(k + 1, 0), prefSum(k + 1, 0);

        for (int i = 1; i <= k; i++)
            pow10[i] = (pow10[i - 1] * 10) % MOD;

        for (int i = 0; i < k; i++) {
            prefVal[i + 1] = (prefVal[i] * 10 + digit[i]) % MOD;
            prefSum[i + 1] = prefSum[i] + digit[i];
        }

        vector<int> ans;

        for (auto &q : queries) {
            int l = lower_bound(pos.begin(), pos.end(), q[0]) - pos.begin();
            int r = upper_bound(pos.begin(), pos.end(), q[1]) - pos.begin() - 1;

            if (l > r) {
                ans.push_back(0);
                continue;
            }

            int len = r - l + 1;

            long long x = (prefVal[r + 1] - prefVal[l] * pow10[len] % MOD + MOD) % MOD;
            long long sum = prefSum[r + 1] - prefSum[l];

            ans.push_back((x * (sum % MOD)) % MOD);
        }

        return ans;
    }
};
